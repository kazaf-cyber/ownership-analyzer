const CODE_GOOGLE = `// ===== Google Custom Search API =====
// ⚠️ 所有關鍵字以 OR 連接，單次搜尋，禁止分批

const { google } = require('googleapis');
const customsearch = google.customsearch('v1');

const GOOGLE_API_KEY = process.env.GOOGLE_API_KEY;
const SEARCH_ENGINE_ID = process.env.SEARCH_ENGINE_ID;

const EN_KEYWORDS = [
  "market abuse","regulatory breach","tax evasion",
  "allegation","bribery","corruption","criminal",
  "fraud","illegal","indict","investigation",
  "laundering","lawsuit","penalty","prosecution",
  "sanctions","terrorist","trafficking","ML","AML"
];

const ZH_KEYWORDS = [
  "市場濫用","監管違規","逃稅","指控","賄賂",
  "腐敗","刑事","欺詐","非法","起訴","調查",
  "洗錢","訴訟","處罰","檢舉","制裁",
  "恐怖分子","販運","洗錢","反洗錢"
];

async function searchAdverseMedia(entityName, language = 'en') {
  const keywords = language === 'en' ? EN_KEYWORDS : ZH_KEYWORDS;

  // ✅ 所有關鍵字用 OR 連接成單一極長字串
  // ❌ 禁止將關鍵字分為多組進行批次搜尋
  const keywordString = keywords.map(k => \\\`"\\\${k}"\\\`).join(' OR ');
  const query = \\\`"\\\${entityName}" \\\${keywordString}\\\`;

  // 單次 API 呼叫，返回前 10 筆結果
  const res = await customsearch.cse.list({
    auth: GOOGLE_API_KEY,
    cx: SEARCH_ENGINE_ID,
    q: query,
    num: 10,     // 最多取回 10 筆
    lr: language === 'zh'
      ? 'lang_zh-TW|lang_zh-CN'
      : 'lang_en',
    dateRestrict: 'y2',   // 最近 2 年
    sort: 'date',
  });

  // 依照 Google 排序，順序編號 #1 至 #10
  return (res.data.items || []).map((item, idx) => ({
    rank: idx + 1,
    title: item.title,
    snippet: item.snippet,
    url: item.link,
    source: item.displayLink,
  }));
}`;

