                    d: 'AI 判斷僅供參考。監管要求合規人員必須人工覆核每個 True Hit，不能完全依賴 AI。',
                  },
                  {
                    t: '🤖 AI API 待接入',
                    d: 'AI 分類的 API endpoint 待客戶提供後替換。目前展示為模擬結果。',
                  },
                  {
                    t: '🌐 多語言',
                    d: '建議香港客戶同時搜尋 EN + ZH。每種語言各返回 10 筆結果。',
                  },
                ].map((n, i) => (
                  <div
                    key={i}
                    className="bg-white rounded-lg p-3 border border-amber-100"
                  >
                    <div className="text-xs font-bold text-amber-800">{n.t}</div>
                    <div className="text-xs text-amber-700 mt-0.5">{n.d}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        {/* ===== CODE TAB ===== */}
        {activeTab === 'code' && (
          <div className="space-y-4">
            <div className="bg-white rounded-xl border shadow-sm p-4">
              <h2 className="text-sm font-bold text-gray-800 mb-3">
                💻 實作程式碼
              </h2>
              <div className="grid grid-cols-3 gap-2">
                {[
                  { k: 'google', l: '🔍 Google Search', d: '單次查詢邏輯' },
                  { k: 'ai', l: '🤖 AI 4類判斷', d: 'Prompt + API 呼叫' },
                  { k: 'api', l: '⚡ Backend API', d: '完整 Endpoint' },
                ].map((c) => (
                  <button
                    key={c.k}
                    onClick={() =>
                      setShowCode(showCode === c.k ? null : c.k)
                    }
                    className={`text-left p-3 rounded-lg border-2 transition ${
                      showCode === c.k
                        ? 'bg-slate-800 text-white border-slate-700'
                        : 'bg-gray-50 hover:bg-gray-100 border-gray-200'
                    }`}
                  >
                    <div className="text-sm font-bold">{c.l}</div>
                    <div
                      className={`text-xs mt-0.5 ${
                        showCode === c.k ? 'text-gray-300' : 'text-gray-500'
                      }`}
                    >
                      {c.d}
                    </div>
                  </button>
                ))}
              </div>
            </div>
            {showCode && (
              <div className="bg-gray-900 rounded-xl overflow-hidden">
                <div className="flex justify-between px-4 py-2 bg-gray-800">
                  <span className="text-xs text-gray-400 font-mono">
                    {showCode}.js
                  </span>
                  <button
                    onClick={() => setShowCode(null)}
                    className="text-gray-400 hover:text-white text-xs"
                  >
                    ✕
                  </button>
                </div>
                <div className="p-4 overflow-auto max-h-96">
                  <pre className="text-xs text-green-400 font-mono whitespace-pre">
                    {showCode === 'google'
                      ? CODE_GOOGLE
                      : showCode === 'ai'
                        ? CODE_AI
                        : CODE_API}
                  </pre>
                </div>
              </div>
            )}
            <div className="bg-blue-50 border-2 border-blue-200 rounded-xl p-4">
              <h2 className="text-xs font-bold text-blue-800 mb-2">
                📦 安裝套件 & 環境變數
              </h2>
              <div className="bg-gray-900 rounded-lg p-3">
                <pre className="text-xs text-green-400 font-mono">
                  {`npm install googleapis express pg

# .env
GOOGLE_API_KEY=your_google_api_key
SEARCH_ENGINE_ID=your_custom_search_engine_id
AI_API_ENDPOINT=待客戶提供
AI_API_KEY=待客戶提供`}
                </pre>
              </div>
            </div>
          </div>
        )}

        {/* ===== KEYWORDS TAB ===== */}
        {activeTab === 'keywords' && (
          <div className="space-y-4">
            <div className="bg-white rounded-xl border shadow-sm p-5">
              <h2 className="text-sm font-bold text-gray-800 mb-1">
                📋 固定關鍵字庫
              </h2>
              <p className="text-xs text-gray-500 mb-4">
                所有關鍵字以 OR 連接成單一字串，進行一次性搜尋（禁止分批）
              </p>
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <h3 className="text-sm font-bold text-blue-700 mb-2">
                    🇬🇧 English Keywords ({EN_KEYWORDS.length})
                  </h3>
                  <div className="flex flex-wrap gap-1.5">
                    {EN_KEYWORDS.map((kw, i) => (
                      <span
                        key={i}
                        className="bg-blue-50 text-blue-700 border border-blue-200 px-2 py-1 rounded-lg text-xs font-mono"
                      >
                        "{kw}"
                      </span>
                    ))}
                  </div>
                  <div className="mt-3 bg-gray-900 rounded-lg p-3 overflow-x-auto">
                    <code className="text-xs text-green-400 font-mono break-all">
                      {EN_KEYWORDS.map((k) => `"${k}"`).join(' OR ')}
                    </code>
                  </div>
                </div>
                <div>
                  <h3 className="text-sm font-bold text-red-700 mb-2">
                    🇨🇳 中文關鍵字 ({ZH_KEYWORDS.length})
                  </h3>
                  <div className="flex flex-wrap gap-1.5">
                    {ZH_KEYWORDS.map((kw, i) => (
                      <span
                        key={i}
                        className="bg-red-50 text-red-700 border border-red-200 px-2 py-1 rounded-lg text-xs font-mono"
                      >
                        "{kw}"
                      </span>
                    ))}
                  </div>
                  <div className="mt-3 bg-gray-900 rounded-lg p-3 overflow-x-auto">
                    <code className="text-xs text-green-400 font-mono break-all">
                      {ZH_KEYWORDS.map((k) => `"${k}"`).join(' OR ')}
                    </code>
                  </div>
                </div>
              </div>
            </div>
            <div className="bg-white rounded-xl border shadow-sm p-5">
              <h2 className="text-sm font-bold text-gray-800 mb-3">
                🔎 完整查詢字串預覽
              </h2>
              <p className="text-xs text-gray-500 mb-3">
                以 "<b>{searchEntity}</b>" 為例：
              </p>
              <div className="space-y-3">
                <div>
                  <div className="text-xs font-bold text-blue-700 mb-1">
                    🇬🇧 English — 單次查詢
                  </div>
                  <div className="bg-gray-900 rounded-lg p-3 overflow-x-auto">
                    <code className="text-xs text-green-400 font-mono break-all">
                      {buildQuery(searchEntity, 'en')}
                    </code>
                  </div>
                </div>
                <div>
                  <div className="text-xs font-bold text-red-700 mb-1">
                    🇨🇳 中文 — 單次查詢
                  </div>
                  <div className="bg-gray-900 rounded-lg p-3 overflow-x-auto">
                    <code className="text-xs text-green-400 font-mono break-all">
                      {buildQuery(searchEntity, 'zh')}
                    </code>
                  </div>
                </div>
              </div>
            </div>
            <div className="bg-green-50 border-2 border-green-200 rounded-xl p-4">
              <h2 className="text-sm font-bold text-green-800 mb-2">
                💡 搜尋策略
              </h2>
              <div className="space-y-2">
                {[
                  {
                    t: '單次查詢原則',
                    d: '所有關鍵字必須用 OR 連接成一個字串，一次 API 呼叫。禁止分組或分批搜尋。',
                  },
                  {
                    t: '精確匹配',
                    d: 'Entity Name 用雙引號包裹（如 "ABC Holdings Ltd"），確保精確匹配而非拆字。',
                  },
                  {
                    t: '取前 10 筆',
                    d: 'Google API 參數 num=10，按照 Google 排序順序返回 #1 至 #10。',
                  },
                  {
                    t: '雙語搜尋',
                    d: 'EN 和 ZH 為兩次獨立查詢，各自返回 10 筆結果，合計最多 20 筆。',
                  },
                ].map((s, i) => (
                  <div
                    key={i}
                    className="bg-white rounded-lg p-3 border border-green-100"
                  >
                    <b className="text-xs text-green-800">{s.t}：</b>
                    <span className="text-xs text-green-700">{s.d}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

