const CODE_API = `// ===== 完整 API Endpoint =====
const express = require('express');
const router = express.Router();

// POST /api/screening/adverse-media
router.post('/adverse-media', async (req, res) => {
  const { clientId, entityName, entityProfile, language } = req.body;
  // language: 'en' | 'zh' | 'both'

  try {
    const allResults = [];

    // Step 1: Google Search (單次查詢，不分批)
    if (language === 'en' || language === 'both') {
      const enResults = await searchAdverseMedia(entityName, 'en');
      allResults.push(...enResults.map(r => ({ ...r, language: 'en' })));
    }
    if (language === 'zh' || language === 'both') {
      const zhResults = await searchAdverseMedia(entityName, 'zh');
      allResults.push(...zhResults.map(r => ({ ...r, language: 'zh' })));
    }

    // Step 2: AI Classification (4 類判斷)
    const classified = [];
    for (const article of allResults) {
      const aiResult = await classifyResult(article, entityProfile);
      classified.push({ ...article, ...aiResult });
      await new Promise(r => setTimeout(r, 300)); // rate limit
    }

    // Step 3: Summary
    const summary = {
      entityName,
      screeningDate: new Date().toISOString(),
      language,
      totalResults: classified.length,
      trueHits:  classified.filter(r => r.classification === 'TRUE_HIT').length,
      falseHits: classified.filter(r => r.classification === 'FALSE_HIT').length,
      irrelevant: classified.filter(r => r.classification === 'IRRELEVANT_MLTF').length,
      noHits:    classified.filter(r => r.classification === 'NO_HIT').length,
      overallRisk: classified.some(r => r.classification === 'TRUE_HIT')
        ? 'HIGH' : 'LOW',
      results: classified,
    };

    // Step 4: Save to DB
